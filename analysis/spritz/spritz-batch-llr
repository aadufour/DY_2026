#!/bin/bash
# spritz-batch-llr: wrapper around spritz-batch that fixes submit.jdl for LLR T3.
# Usage: run from inside apptainer in the config directory, same as spritz-batch.

set -e

PROXY=/grid_mnt/data__data.polcms/cms/adufour/proxy.pem

# Derive cfg.json path from SPRITZ_PATH (set in ~/.bashrc)
FW_PATH=${SPRITZ_PATH:-/grid_mnt/data__data.polcms/cms/adufour/spritz_fabian}
CFG_JSON=${FW_PATH}/data/Full2018v9/cfg.json

# Get the runner name from config.py in the current directory
RUNNER_NAME=$(python3 -c "
import sys, re
txt = open('config.py').read()
m = re.search(r'runner\s*=\s*[\"\'f].*?([^\\/\"\']+\.py)[\"\'\\)]', txt)
print(m.group(1) if m else 'runner.py')
" 2>/dev/null || echo "runner.py")

spritz-batch

# Fix submit.jdl for LLR T3
JDL=condor/submit.jdl

sed -i \
  -e '/MY.SingularityImage/d' \
  -e "s|/tmp/x509up_u[0-9]*, ||" \
  -e '/Requirements/d' \
  -e '/+JobFlavour/d' \
  -e "s|/opt/spritz/data/Full2018v9/cfg.json|${CFG_JSON}|" \
  -e '/^log/a T3Queue = short\nWNTag   = el9\ninclude : /opt/exp_soft/cms/t3/t3queue |' \
  "$JDL"

echo "submit.jdl patched for LLR T3."

# Fix run.sh: replace with apptainer call + gridmount proxy
cat > condor/run.sh << RUNEOF
#!/bin/bash
export X509_USER_PROXY=/grid_mnt/data__data.polcms/cms/adufour/proxy.pem
time apptainer exec \
    -B /etc/grid-security/certificates:/etc/grid-security/certificates \
    -B /cvmfs \
    -B /grid_mnt \
    /grid_mnt/data__data.polcms/cms/adufour/spritz-env.sif \
    python ${RUNNER_NAME} .
RUNEOF
chmod +x condor/run.sh

echo "run.sh patched for LLR T3 (apptainer + gridmount proxy)."
echo "Submit with: cd condor && condor_submit submit.jdl"
